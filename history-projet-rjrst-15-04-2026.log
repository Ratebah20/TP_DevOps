 1047  2026-04-16 12:51  cat > .gitlab-ci.yml << 'PIPELINE_EOF'\n# Pipeline DevOps - Projet Final\n# Equipe: Rateb, Jonathan, Romain, Soulymane, Tomy (RJRST)\n# Date: 15-04-2026\n\nstages:\n  - build_dev\n  - build_prod\n  - test\n  - security_scan\n  - deploy_staging\n  - deploy_production\n  - backup\n  - rollback\n\nvariables:\n  DOCKER_HOST: unix:///var/run/docker.sock\n  APP_NAME: ecommerce-rjrst-15-04-2026\n  NETWORK_NAME: network-rjrst-15-04-2026\n\n# ============================================\n# STAGE 1: BUILD DEV (image basique)\n# ============================================\nbuild_dev:\n  stage: build_dev\n  image: docker:latest\n  tags:\n    - local\n  script:\n    - echo "=== BUILD DEV IMAGE ==="\n    - cd app\n    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY\n    - docker build -t $CI_REGISTRY_IMAGE:dev -f Dockerfile.dev .\n    - docker push $CI_REGISTRY_IMAGE:dev\n    - echo "=== Image DEV size ==="\n    - docker images $CI_REGISTRY_IMAGE:dev --format "{{.Size}}"\n\n# ============================================\n# STAGE 2: BUILD PROD (image optimisée)\n# ============================================\nbuild_prod:\n  stage: build_prod\n  image: docker:latest\n  tags:\n    - local\n  script:\n    - echo "=== BUILD PROD IMAGE (optimized) ==="\n    - cd app\n    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY\n    - docker build -t $CI_REGISTRY_IMAGE:prod -t $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA -f Dockerfile.prod .\n    - docker push $CI_REGISTRY_IMAGE:prod\n    - docker push $CI_REGISTRY_IMAGE:$CI_COMMIT_SHORT_SHA\n    - echo "=== Image PROD size ==="\n    - docker images $CI_REGISTRY_IMAGE:prod --format "{{.Size}}"\n    - echo "Commit SHA tagged: $CI_COMMIT_SHORT_SHA"\n\n# ============================================\n# STAGE 3: TEST (tests Django)\n# ============================================\ntest:\n  stage: test\n  image: docker:latest\n  tags:\n    - local\n  script:\n    - echo "=== RUNNING DJANGO TESTS ==="\n    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY\n    - docker pull $CI_REGISTRY_IMAGE:prod\n    - docker run --rm\n      -e DB_ENGINE=sqlite3\n      -e DB_NAME=/tmp/test.db\n      -e SECRET_KEY=test-secret\n      -e DEBUG=True\n      --entrypoint ""\n      $CI_REGISTRY_IMAGE:prod\n      sh -c "python manage.py check && python manage.py makemigrations --check --dry-run || true"\n    - echo "=== Tests passed ==="\n\n# ============================================\n# STAGE 4: SECURITY SCAN (Trivy)\n# ============================================\nsecurity_scan:\n  stage: security_scan\n  image: docker:latest\n  tags:\n    - local\n  script:\n    - echo "=== TRIVY SECURITY SCAN ==="\n    - docker run --rm\n      -v /var/run/docker.sock:/var/run/docker.sock\n      aquasec/trivy:latest image\n      --severity HIGH,CRITICAL\n      --exit-code 0\n      --no-progress\n      $CI_REGISTRY_IMAGE:prod\n  allow_failure: true\n\n# ============================================\n# STAGE 5: DEPLOY STAGING (automatique)\n# ============================================\ndeploy_staging:\n  stage: deploy_staging\n  image: docker:latest\n  tags:\n    - staging\n  environment:\n    name: staging\n    url: http://192.168.64.2:8001\n  script:\n    - echo "=== DEPLOY TO STAGING ==="\n    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY\n    - docker pull $CI_REGISTRY_IMAGE:prod\n    # Créer le réseau si n'existe pas\n    - docker network create $NETWORK_NAME-staging 2>/dev/null || true\n    # Lancer la DB si elle n'existe pas\n    - |\n      if ! docker ps -a -q -f name=db-staging-rjrst | grep -q .; then\n        docker run -d --name db-staging-rjrst \\n          --network $NETWORK_NAME-staging \\n          --restart unless-stopped \\n          -e POSTGRES_DB=appdb \\n          -e POSTGRES_USER=appuser \\n          -e POSTGRES_PASSWORD=apppass \\n          -v db-staging-data:/var/lib/postgresql/data \\n          postgres:16-alpine\n        sleep 10\n      fi\n    # Stopper l'ancien conteneur app\n    - docker stop app-staging-rjrst 2>/dev/null || true\n    - docker rm app-staging-rjrst 2>/dev/null || true\n    # Lancer l'app staging\n    - docker run -d\n      --name app-staging-rjrst\n      --network $NETWORK_NAME-staging\n      --restart unless-stopped\n      -p 8001:8000\n      -e DB_ENGINE=postgresql\n      -e DB_NAME=appdb\n      -e DB_USERNAME=appuser\n      -e DB_PASS=apppass\n      -e DB_HOST=db-staging-rjrst\n      -e DB_PORT=5432\n      -e SECRET_KEY=staging-secret-key\n      -e DEBUG=False\n      -e DJANGO_SUPERUSER_USERNAME=admin\n      -e DJANGO_SUPERUSER_EMAIL=admin@rjrst.local\n      -e DJANGO_SUPERUSER_PASSWORD=admin123\n      -v app-staging-backups:/app/backups\n      $CI_REGISTRY_IMAGE:prod\n    - sleep 5\n    - echo "=== Staging deployed on http://192.168.64.2:8001 ==="\n\n# ============================================\n# STAGE 6: DEPLOY PRODUCTION (manuel)\n# ============================================\ndeploy_production:\n  stage: deploy_production\n  image: docker:latest\n  tags:\n    - production\n  environment:\n    name: production\n    url: http://192.168.64.2:8000\n  when: manual\n  only:\n    - main\n  script:\n    - echo "=== DEPLOY TO PRODUCTION ==="\n    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY\n    - docker pull $CI_REGISTRY_IMAGE:prod\n    # Créer le réseau si n'existe pas\n    - docker network create $NETWORK_NAME-prod 2>/dev/null || true\n    # Lancer la DB si elle n'existe pas\n    - |\n      if ! docker ps -a -q -f name=db-prod-rjrst | grep -q .; then\n        docker run -d --name db-prod-rjrst \\n          --network $NETWORK_NAME-prod \\n          --restart unless-stopped \\n          -e POSTGRES_DB=appdb \\n          -e POSTGRES_USER=appuser \\n          -e POSTGRES_PASSWORD=apppass \\n          -v db-prod-data:/var/lib/postgresql/data \\n          postgres:16-alpine\n        sleep 10\n      fi\n    # Sauvegarder le tag actuel pour rollback\n    - |\n      OLD_IMAGE=$(docker inspect app-prod-rjrst --format '{{.Config.Image}}' 2>/dev/null || echo "none")\n      echo "Previous image: $OLD_IMAGE"\n      docker tag $OLD_IMAGE $CI_REGISTRY_IMAGE:previous 2>/dev/null || true\n    # Stopper l'ancien conteneur\n    - docker stop app-prod-rjrst 2>/dev/null || true\n    - docker rm app-prod-rjrst 2>/dev/null || true\n    # Lancer l'app prod\n    - docker run -d\n      --name app-prod-rjrst\n      --network $NETWORK_NAME-prod\n      --restart unless-stopped\n      -p 8000:8000\n      -e DB_ENGINE=postgresql\n      -e DB_NAME=appdb\n      -e DB_USERNAME=appuser\n      -e DB_PASS=apppass\n      -e DB_HOST=db-prod-rjrst\n      -e DB_PORT=5432\n      -e SECRET_KEY=prod-super-secret-key\n      -e DEBUG=False\n      -e DJANGO_SUPERUSER_USERNAME=admin\n      -e DJANGO_SUPERUSER_EMAIL=admin@rjrst.local\n      -e DJANGO_SUPERUSER_PASSWORD=admin123\n      -v app-prod-backups:/app/backups\n      $CI_REGISTRY_IMAGE:prod\n    - sleep 5\n    - echo "=== Production deployed on http://192.168.64.2:8000 ==="\n\n# ============================================\n# STAGE 7: BACKUP DB (manuel)\n# ============================================\nbackup_db:\n  stage: backup\n  image: docker:latest\n  tags:\n    - production\n  when: manual\n  script:\n    - echo "=== BACKUP PRODUCTION DATABASE ==="\n    - TIMESTAMP=$(date +%Y%m%d_%H%M%S)\n    - docker exec app-prod-rjrst python manage.py dbbackup\n    - docker exec app-prod-rjrst ls -la /app/backups/\n    - echo "=== Backup created at $TIMESTAMP ==="\n\n# ============================================\n# STAGE 8: ROLLBACK (manuel)\n# ============================================\nrollback:\n  stage: rollback\n  image: docker:latest\n  tags:\n    - production\n  when: manual\n  script:\n    - echo "=== ROLLBACK TO PREVIOUS VERSION ==="\n    - docker login -u $CI_REGISTRY_USER -p $CI_REGISTRY_PASSWORD $CI_REGISTRY\n    # Stopper l'app actuelle\n    - docker stop app-prod-rjrst 2>/dev/null || true\n    - docker rm app-prod-rjrst 2>/dev/null || true\n    # Relancer avec l'image previous\n    - docker run -d\n      --name app-prod-rjrst\n      --network $NETWORK_NAME-prod\n      --restart unless-stopped\n      -p 8000:8000\n      -e DB_ENGINE=postgresql\n      -e DB_NAME=appdb\n      -e DB_USERNAME=appuser\n      -e DB_PASS=apppass\n      -e DB_HOST=db-prod-rjrst\n      -e DB_PORT=5432\n      -e SECRET_KEY=prod-super-secret-key\n      -e DEBUG=False\n      -v app-prod-backups:/app/backups\n      $CI_REGISTRY_IMAGE:previous\n    - echo "=== Rollback complete ==="\nPIPELINE_EOF
